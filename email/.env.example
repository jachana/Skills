# email — OPTIONAL environment variables.
# The skill works WITHOUT any of these: you paste the incoming email in and it
# drafts the reply (you send it yourself). Set these only if you want the skill
# to read/send mail directly. Never commit the real .env.

# --- IMAP (reading) ---
IMAP_HOST=          # e.g. imap.gmail.com
IMAP_PORT=993
IMAP_USER=          # your email address
IMAP_PASSWORD=      # app password / token — NOT your main password

# --- SMTP (sending) ---
SMTP_HOST=          # e.g. smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Where to keep thread-tracking markdown (default: ./email-threads)
EMAIL_THREADS_DIR=
