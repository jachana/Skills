# trello — environment variables
# Copy to ".env" and fill in YOUR values. Never commit the real .env.
# ALL THREE are optional: without them the `ship` skill + board.py run fully
# OFFLINE against a local board.json. Set them to mirror to a real Trello board.

# Trello API key — https://trello.com/app-key
TRELLO_API_KEY=

# Trello token — generate from the same page (click "Token"), grant read/write.
TRELLO_TOKEN=

# The board id to sync with. Open the board in a browser:
#   https://trello.com/b/<BOARD_ID>/<slug>   <-- the <BOARD_ID> segment.
TRELLO_BOARD_ID=
